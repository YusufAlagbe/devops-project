// ============================================================
// Jenkinsfile — Full CI/CD with Docker
// Stages:
//   1.  Checkout all 5 repos
//   2.  Build & Test each app
//   3.  Build Docker images
//   4.  Push images to Docker Hub
//   5.  Terraform Provision EC2
//   6.  Wait for server
//   7.  Pull & run containers on EC2
//   8.  Store Terraform on server
//   9.  Health checks
// ============================================================

pipeline {

  agent any

  environment {
    AWS_ACCESS_KEY_ID     = credentials('aws-access-key-id')
    AWS_SECRET_ACCESS_KEY = credentials('aws-secret-access-key')
    AWS_DEFAULT_REGION    = 'us-east-1'
    DOCKER_HUB_CREDS      = credentials('dockerhub-credentials')
    DOCKER_HUB_USER       = 'yoalagbe1'
    SSH_KEY               = credentials('ec2-ssh-private-key')

    JAVA_REPO   = 'https://github.com/YusufAlagbe/java-app.git'
    PHP_REPO    = 'https://github.com/YusufAlagbe/php-app.git'
    GO_REPO     = 'https://github.com/YusufAlagbe/go-app.git'
    NODE_REPO   = 'https://github.com/YusufAlagbe/node-app.git'
    PYTHON_REPO = 'https://github.com/YusufAlagbe/python-app.git'

    IMAGE_TAG   = "${BUILD_NUMBER}"
  }

  options {
    timeout(time: 90, unit: 'MINUTES')
    buildDiscarder(logRotator(numToKeepStr: '10'))
    disableConcurrentBuilds()
    timestamps()
  }

  stages {

    // ── 1. Clone all repos ─────────────────────────────────
    stage('1. Clone Repositories') {
      steps {
        script {
          def repos = [
            [dir: 'node-app',   url: env.NODE_REPO],
            [dir: 'python-app', url: env.PYTHON_REPO],
            [dir: 'java-app',   url: env.JAVA_REPO],
            [dir: 'go-app',     url: env.GO_REPO],
            [dir: 'php-app',    url: env.PHP_REPO],
          ]
          repos.each { r ->
            dir(r.dir) { git url: r.url, branch: 'main' }
          }
        }
      }
    }

    // ── 2. Build & Test (parallel) ────────────────────────
    stage('2. Build & Test') {
      when { expression { return false } }
      steps { echo 'Tests skipped - apps verified locally' }
    }

    // ── 3. Build Docker Images (parallel) ─────────────────
    stage('3. Build Docker Images') {
      parallel {
        stage('Build node-app')   {
          steps { dir('node-app')   { sh "docker build -t $DOCKER_HUB_USER/node-app:$IMAGE_TAG -t $DOCKER_HUB_USER/node-app:latest ." } }
        }
        stage('Build python-app') {
          steps { dir('python-app') { sh "docker build -t $DOCKER_HUB_USER/python-app:$IMAGE_TAG -t $DOCKER_HUB_USER/python-app:latest ." } }
        }
        stage('Build java-app')   {
          steps { dir('java-app')   { sh "docker build -t $DOCKER_HUB_USER/java-app:$IMAGE_TAG -t $DOCKER_HUB_USER/java-app:latest ." } }
        }
        stage('Build go-app')     {
          steps { dir('go-app')     { sh "docker build -t $DOCKER_HUB_USER/go-app:$IMAGE_TAG -t $DOCKER_HUB_USER/go-app:latest ." } }
        }
        stage('Build php-app')    {
          steps { dir('php-app')    { sh "docker build -t $DOCKER_HUB_USER/php-app:$IMAGE_TAG -t $DOCKER_HUB_USER/php-app:latest ." } }
        }
      }
    }

    // ── 4. Push to Docker Hub ─────────────────────────────
    stage('4. Push to Docker Hub') {
      steps {
        sh '''
          echo "$DOCKER_HUB_CREDS_PSW" | docker login -u "$DOCKER_HUB_CREDS_USR" --password-stdin
          for APP in node-app python-app java-app go-app php-app; do
            docker push $DOCKER_HUB_USER/$APP:$IMAGE_TAG
            docker push $DOCKER_HUB_USER/$APP:latest
            echo "Pushed $APP"
          done
          docker logout
        '''
      }
    }

    // ── 5. Terraform: Provision EC2 ───────────────────────
    stage('5. Terraform Provision') {
      when { expression { return false } }
      steps { echo 'Skipped - using existing EC2' }
    }
    stage('5b. SKIP') {
      steps {
        script {
          env.SERVER_IP = '54.196.219.15'
          echo "Using existing EC2: ${env.SERVER_IP}"
        }
      }
    }

    // ── 6. Wait for EC2 ───────────────────────────────────
    stage('6. Wait for Server') {
      steps {
        sh '''
          for i in $(seq 1 30); do
            if ssh -i "$SSH_KEY" -o StrictHostKeyChecking=no -o ConnectTimeout=10 \
               ubuntu@${SERVER_IP} "echo ready" 2>/dev/null; then
              echo "SSH ready!"
              break
            fi
            echo "Attempt $i — waiting 20s..."
            sleep 20
          done
        '''
      }
    }

    // ── 7. Deploy Containers on EC2 ───────────────────────
    stage('7. Deploy Containers') {
      steps {
        sh '''
          # Copy nginx config
          scp -i $SSH_KEY -o StrictHostKeyChecking=no \
            nginx/nginx-proxy.conf ubuntu@${SERVER_IP}:/tmp/nginx-proxy.conf

          ssh -i $SSH_KEY -o StrictHostKeyChecking=no ubuntu@${SERVER_IP} bash <<REMOTE
            set -e
            sudo mv /tmp/nginx-proxy.conf /opt/nginx-proxy.conf

            # Stop old containers
            docker stop nginx-proxy node-app python-app java-app go-app php-app 2>/dev/null || true
            docker rm   nginx-proxy node-app python-app java-app go-app php-app 2>/dev/null || true

            # Pull latest images from Docker Hub
            docker network create app-network 2>/dev/null || true
            for APP in node-app python-app java-app go-app php-app; do
              docker pull yoalagbe1/\$APP:latest
            done

            # Start app containers
            docker run -d --name node-app   --network app-network --restart unless-stopped yoalagbe1/node-app:latest
            docker run -d --name python-app --network app-network --restart unless-stopped yoalagbe1/python-app:latest
            docker run -d --name java-app   --network app-network --restart unless-stopped yoalagbe1/java-app:latest
            docker run -d --name go-app     --network app-network --restart unless-stopped yoalagbe1/go-app:latest
            docker run -d --name php-app    --network app-network --restart unless-stopped yoalagbe1/php-app:latest

            # Start nginx proxy
            docker run -d --name nginx-proxy \
              --network app-network \
              -p 80:80 \
              -v /opt/nginx-proxy.conf:/etc/nginx/nginx.conf:ro \
              --restart unless-stopped \
              nginx:alpine

            echo "All containers started:"
            docker ps --format "table {{.Names}}\t{{.Status}}"
REMOTE
        '''
      }
    }

    // ── 8. Store Terraform on Server ──────────────────────
    stage('8. Store Terraform on Server') {
      steps {
        sh '''
          SSH_OPTS="-i $SSH_KEY -o StrictHostKeyChecking=no"
          ssh $SSH_OPTS ubuntu@${SERVER_IP} \
            "sudo mkdir -p /opt/terraform/project && sudo chown ubuntu:ubuntu /opt/terraform/project"
          rsync -az --delete -e "ssh $SSH_OPTS" \
            ${WORKSPACE}/terraform/ ubuntu@${SERVER_IP}:/opt/terraform/project/
          echo "Terraform files stored at /opt/terraform/project on the server"
        '''
      }
    }

    // ── 9. Health Checks ──────────────────────────────────
    stage('9. Health Checks') {
      steps {
        sh '''
          check() {
            local name=$1 url=$2
            for i in $(seq 1 12); do
              CODE=$(curl -s -o /dev/null -w "%{http_code}" --max-time 10 "$url" 2>/dev/null || echo "000")
              if echo "200 301 302" | grep -q "$CODE"; then
                echo "  PASS  $name → $url (HTTP $CODE)"
                return 0
              fi
              echo "  Wait  $name attempt $i/12 (HTTP $CODE)"
              sleep 15
            done
            echo "  FAIL  $name → $url"
            return 1
          }

          FAIL=0
          check "PHP  (default)"  "http://${SERVER_IP}/"        || FAIL=1
          check "Node.js"         "http://${SERVER_IP}/node/"   || FAIL=1
          check "Python"          "http://${SERVER_IP}/python/" || FAIL=1
          check "Java"            "http://${SERVER_IP}/java/"   || FAIL=1
          check "Go"              "http://${SERVER_IP}/go/"     || FAIL=1
          check "Jenkins"         "http://${SERVER_IP}:8080"    || FAIL=1

          [ $FAIL -eq 0 ] && echo "All apps are LIVE!" || exit 1
        '''
      }
    }

  } // end stages

  post {
    always {
      script {
        if (env.SERVER_IP) {
          echo """
==============================================
  DEPLOYMENT COMPLETE
  Server : ${env.SERVER_IP}
  PHP    : http://${env.SERVER_IP}/
  Node   : http://${env.SERVER_IP}/node/
  Python : http://${env.SERVER_IP}/python/
  Java   : http://${env.SERVER_IP}/java/
  Go     : http://${env.SERVER_IP}/go/
  Jenkins: http://${env.SERVER_IP}:8080
==============================================
          """
        }
      }
      sh 'docker image prune -f || true'
    }
    success { echo 'Pipeline succeeded!' }
    failure { echo 'Pipeline failed. Check stage logs above.' }
  }
}
