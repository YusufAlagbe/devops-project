pipeline {
  agent any
  environment {
    DOCKER_HUB_USER    = 'yoalagbe1'
    SSH_KEY            = credentials('ec2-ssh-private-key')
    DOCKER_HUB_CREDS   = credentials('dockerhub-credentials')
    AWS_ACCESS_KEY_ID  = credentials('aws-access-key-id')
    AWS_SECRET_ACCESS_KEY = credentials('aws-secret-access-key')
    SERVER_IP          = ''
  }
  options {
    timeout(time: 1, unit: 'HOURS')
    timestamps()
  }
  stages {
    stage('1. Clone Repositories') {
      steps {
        script {
          def apps = ['node-app','python-app','java-app','go-app','php-app']
          apps.each { app ->
            dir(app) {
              git url: "https://github.com/YusufAlagbe/${app}.git", branch: 'main'
            }
          }
        }
      }
    }
    stage('2. Build & Test') {
      when { expression { false } }
      steps { echo 'Skipped' }
    }
    stage('3. Build Docker Images') {
      steps {
        parallel(
          'Build node-app':   { dir('node-app')   { sh "docker build -t yoalagbe1/node-app:${BUILD_NUMBER} -t yoalagbe1/node-app:latest ." } },
          'Build python-app': { dir('python-app') { sh "docker build -t yoalagbe1/python-app:${BUILD_NUMBER} -t yoalagbe1/python-app:latest ." } },
          'Build java-app':   { dir('java-app')   { sh "docker build -t yoalagbe1/java-app:${BUILD_NUMBER} -t yoalagbe1/java-app:latest ." } },
          'Build go-app':     { dir('go-app')     { sh "docker build -t yoalagbe1/go-app:${BUILD_NUMBER} -t yoalagbe1/go-app:latest ." } },
          'Build php-app':    { dir('php-app')    { sh "docker build -t yoalagbe1/php-app:${BUILD_NUMBER} -t yoalagbe1/php-app:latest ." } }
        )
      }
    }
    stage('4. Push to Docker Hub') {
      steps {
        sh '''
          echo $DOCKER_HUB_CREDS_PSW | docker login -u yoalagbe1 --password-stdin
          docker push yoalagbe1/node-app:''' + env.BUILD_NUMBER + '''
          docker push yoalagbe1/node-app:latest
          echo "Pushed node-app"
          docker push yoalagbe1/python-app:''' + env.BUILD_NUMBER + '''
          docker push yoalagbe1/python-app:latest
          echo "Pushed python-app"
          docker push yoalagbe1/java-app:''' + env.BUILD_NUMBER + '''
          docker push yoalagbe1/java-app:latest
          echo "Pushed java-app"
          docker push yoalagbe1/go-app:''' + env.BUILD_NUMBER + '''
          docker push yoalagbe1/go-app:latest
          echo "Pushed go-app"
          docker push yoalagbe1/php-app:''' + env.BUILD_NUMBER + '''
          docker push yoalagbe1/php-app:latest
          echo "Pushed php-app"
          docker logout
        '''
      }
    }
    stage('5. Terraform Provision') {
      when { expression { false } }
      steps { echo 'Skipped' }
    }
    stage('5b. SKIP') {
      steps {
        script {
          env.SERVER_IP = '54.196.219.15'
          echo "Using existing EC2: ${env.SERVER_IP}"
        }
      }
    }
    stage('6. Wait for Server') {
      steps {
        sh '''
          for i in $(seq 1 30); do
            if ssh -i $SSH_KEY -o StrictHostKeyChecking=no -o ConnectTimeout=10 ubuntu@54.196.219.15 echo ready; then
              echo "SSH ready!"
              break
            fi
            sleep 10
          done
        '''
      }
    }
    stage('7. Deploy Containers') {
      steps {
        sh '''
          cat > /tmp/deploy.sh << 'SCRIPT'
set -e
sudo mv /tmp/nginx-proxy.conf /opt/nginx-proxy.conf
docker stop nginx-proxy node-app python-app java-app go-app php-app 2>/dev/null || true
docker rm nginx-proxy node-app python-app java-app go-app php-app 2>/dev/null || true
docker network create app-network 2>/dev/null || true
docker pull yoalagbe1/node-app:latest
docker pull yoalagbe1/python-app:latest
docker pull yoalagbe1/java-app:latest
docker pull yoalagbe1/go-app:latest
docker pull yoalagbe1/php-app:latest
docker run -d --name node-app --network app-network --restart unless-stopped yoalagbe1/node-app:latest
docker run -d --name python-app --network app-network --restart unless-stopped yoalagbe1/python-app:latest
docker run -d --name java-app --network app-network --restart unless-stopped yoalagbe1/java-app:latest
docker run -d --name go-app --network app-network --restart unless-stopped yoalagbe1/go-app:latest
docker run -d --name php-app --network app-network --restart unless-stopped yoalagbe1/php-app:latest
docker run -d --name nginx-proxy --network app-network -p 80:80 -v /opt/nginx-proxy.conf:/etc/nginx/nginx.conf:ro --restart unless-stopped nginx:alpine
docker ps --format "table {{.Names}}\t{{.Status}}"
SCRIPT
          scp -i $SSH_KEY -o StrictHostKeyChecking=no nginx/nginx-proxy.conf ubuntu@54.196.219.15:/tmp/nginx-proxy.conf
          ssh -i $SSH_KEY -o StrictHostKeyChecking=no ubuntu@54.196.219.15 bash < /tmp/deploy.sh
        '''
      }
    }
    stage('8. Store Terraform on Server') {
      when { expression { false } }
      steps {
        sh '''
          ssh -i $SSH_KEY -o StrictHostKeyChecking=no ubuntu@54.196.219.15 "sudo mkdir -p /opt/terraform/project && sudo chown ubuntu:ubuntu /opt/terraform/project"
          rsync -az --delete -e "ssh -i $SSH_KEY -o StrictHostKeyChecking=no" ${WORKSPACE}/terraform/ ubuntu@54.196.219.15:/opt/terraform/project/
        '''
      }
    }
    stage('9. Health Checks') {
      steps {
        sh '''
          sleep 15
          curl -s -o /dev/null -w "PHP: %{http_code}\n" http://54.196.219.15/ || true
          curl -s -o /dev/null -w "Node: %{http_code}\n" http://54.196.219.15/node/ || true
          curl -s -o /dev/null -w "Python: %{http_code}\n" http://54.196.219.15/python/ || true
          curl -s -o /dev/null -w "Java: %{http_code}\n" http://54.196.219.15/java/ || true
          curl -s -o /dev/null -w "Go: %{http_code}\n" http://54.196.219.15/go/ || true
        '''
      }
    }
  }
  post {
    always {
      script {
        echo """
==============================================
  Server : 54.196.219.15
  PHP    : http://54.196.219.15/
  Node   : http://54.196.219.15/node/
  Python : http://54.196.219.15/python/
  Java   : http://54.196.219.15/java/
  Go     : http://54.196.219.15/go/
==============================================
        """
      }
      sh 'docker image prune -f || true'
    }
  }
}
